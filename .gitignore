# --- Secrets (never commit) ---
.env
.env.*
!.env.example

# --- Node / TypeScript (crucible CLI + Console) ---
node_modules/
dist/
*.tsbuildinfo
npm-debug.log*

# --- Java / Gradle (target system + oracles) ---
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# --- Work-order ephemera ---
# Implementation context bundles are regenerated by `crucible package`; never committed.
workorders/*/bundle/
# NOTE: workorders/*/runlog/ IS committed — it is the sandbox audit trail (see impl plan §4.4).

# --- OS / editor noise ---
.DS_Store
*.swp
.idea/
.vscode/
