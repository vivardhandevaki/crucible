{
  "name": "@crucible/cli",
  "version": "0.1.0",
  "description": "The crucible CLI: work-order lifecycle, state machine, and consumer-repo scaffolding for the Crucible framework.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "crucible": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
