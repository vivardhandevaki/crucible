    "test": "vitest run"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "commander": "15.0.0",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
