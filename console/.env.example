# Crucible Console — local configuration. Copy to `console/.env` (gitignored).
# The Console is a view/remote-control over a Crucible consumer repo; it holds no
# state itself. All of these are optional — missing ones degrade gracefully.

# The Crucible consumer repo the Console operates on (default: current directory).
CRUCIBLE_REPO=/absolute/path/to/your-crucible-project

# GitHub owner PAT — enables PR/check status, the review queue, and approvals.
# Without it the board still renders; GitHub panes show a degraded state.
GITHUB_TOKEN=ghp_xxx

# Claude subscription token for the spec-drafting chat (New Feature screen).
# Mint with `claude setup-token`. Without it, spec-chat is disabled.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat-xxx

# Optional: server port (default 7317).
# CONSOLE_PORT=7317
