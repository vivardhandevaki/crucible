{
  "name": "@crucible/console-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Stateless Console server — a view and remote control over the Crucible state machine. Git + GitHub are the only sources of truth.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@crucible/cli": "file:../../packages/cli",
    "@octokit/rest": "21.1.1",
    "express": "4.21.2",
    "simple-git": "3.27.0",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "22.20.1",
    "@types/supertest": "6.0.2",
    "supertest": "7.0.0",
    "tsx": "4.19.2",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
